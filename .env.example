# --- Runtime mode -----------------------------------------------------------
# true  = no external services needed: seed campaigns + leads, posts written to
#         data/published/ instead of hitting real platform APIs
# false = real LinkedIn / X / Facebook publishing (requires platform tokens below)
DEMO_MODE=true

# --- Admin API auth ----------------------------------------------------------
# Protects the campaigns + lead inbox endpoints when DEMO_MODE=false. Send it as
# the X-API-Key request header. The inbound lead webhook stays open. Leave empty
# in demo mode (auth is disabled there).
ADMIN_API_KEY=

# --- Lead webhook hardening --------------------------------------------------
# The lead webhook is intentionally unauthenticated so any form provider can
# POST to it, so it has its own guards instead.
# Max accepted requests per caller IP per minute (0 disables the limit).
WEBHOOK_RATE_LIMIT_PER_MINUTE=60
# Reject any webhook body larger than this many bytes.
WEBHOOK_MAX_BYTES=16384
# Optional shared secret. When set, callers must send the same value as the
# X-Webhook-Secret header. Leave empty to keep the webhook open.
WEBHOOK_SECRET=

# --- Database ----------------------------------------------------------------
# SQLite for demo; swap for PostgreSQL in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/marketing
DATABASE_URL=sqlite:///./data/marketing.db

# --- Scheduler ----------------------------------------------------------------
# How often the dispatcher checks for due campaigns
DISPATCH_INTERVAL_MINUTES=5

# --- Platforms ----------------------------------------------------------------
# Comma-separated list of platforms the scheduler will publish to.
# Adding a platform is one new adapter file plus its name here.
ENABLED_PLATFORMS=linkedin,twitter,facebook

# In DEMO_MODE this platform simulates a transient outage: its first publish
# attempt fails, but a retry succeeds. Lets you see PARTIAL status, the retry
# button, and recovery to PUBLISHED. Leave empty for an all-green demo.
DEMO_FLAKY_PLATFORM=facebook

# --- Platform credentials (only used when DEMO_MODE=false) --------------------
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- Lead capture + routing ---------------------------------------------------
# Where qualified leads are emailed. Default contact catches anything unrouted.
LEAD_DEFAULT_CONTACT=sales@example.com
# JSON object mapping a service interest to the contact who should own it.
# LEAD_ROUTING={"automation": "auto@example.com", "transport": "ops@example.com"}

# --- Paths --------------------------------------------------------------------
PUBLISHED_DIR=data/published
SEED_CAMPAIGNS_FILE=seed/campaigns.json
SEED_LEADS_FILE=seed/leads.json
